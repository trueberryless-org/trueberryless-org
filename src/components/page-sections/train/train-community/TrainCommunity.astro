---
import CustomSection from "@builders/custom-section/CustomSection.astro";
import Heading from "@core-elements/heading/Heading.astro";
import SimpleText from "@core-elements/simple-text/SimpleText.astro";
import Text from "@core-elements/text/Text.astro";

type StatItem = {
  value?: string;
  label?: string;
};

const {
  eyebrow = "",
  heading = "",
  subtext = "",
  stats = [],
  colorScheme = "inherit",
  backgroundColor,
  paddingVertical = "4xl",
  class: className,
  useDefaultEditableBinding = false,
  _component,
  ...htmlAttributes
} = Astro.props;
---

<CustomSection
  class:list={["train-community", className]}
  maxContentWidth="2xl"
  paddingHorizontal="lg"
  paddingVertical={paddingVertical}
  colorScheme={colorScheme}
  backgroundColor={backgroundColor}
  useDefaultEditableBinding={useDefaultEditableBinding}
  id="community"
  {...htmlAttributes}
>
  <div class="train-community-inner">
    <div class="train-community-track-space"></div>
    <div class="train-community-content">
      <!-- Mobile floating red + green wagons coupled -->
      <div
        class="train-mobile-float train-mobile-float-pair"
        aria-hidden="true"
      >
        <svg
          width="64"
          height="44"
          viewBox="0 0 64 44"
          xmlns="http://www.w3.org/2000/svg"
          style="transform: scaleY(-1);"
        >
          <rect
            x="0"
            y="18"
            width="4"
            height="8"
            rx="1"
            fill="var(--train-gray)"
          ></rect>
          <rect
            x="6"
            y="12"
            width="52"
            height="26"
            rx="4"
            fill="var(--train-red)"
          ></rect>
          <rect
            x="10"
            y="26"
            width="44"
            height="8"
            rx="2"
            fill="#ff8a80"
          ></rect>
          <circle
            cx="18"
            cy="20"
            r="3"
            fill="#ff8a80"
            opacity="0.6"
          ></circle>
          <circle
            cx="32"
            cy="20"
            r="3"
            fill="#ff8a80"
            opacity="0.6"
          ></circle>
          <circle
            cx="46"
            cy="20"
            r="3"
            fill="#ff8a80"
            opacity="0.6"
          ></circle>
          <circle
            cx="18"
            cy="6"
            r="6"
            fill="var(--train-dark)"
          ></circle>
          <circle
            cx="18"
            cy="6"
            r="3"
            fill="var(--train-gray)"
          ></circle>
          <circle
            cx="46"
            cy="6"
            r="6"
            fill="var(--train-dark)"
          ></circle>
          <circle
            cx="46"
            cy="6"
            r="3"
            fill="var(--train-gray)"
          ></circle>
          <rect
            x="58"
            y="18"
            width="6"
            height="8"
            rx="1"
            fill="var(--train-gray)"
          ></rect>
        </svg>
        <svg
          width="64"
          height="44"
          viewBox="0 0 64 44"
          xmlns="http://www.w3.org/2000/svg"
          style="transform: scaleY(-1); margin-left: -4px;"
        >
          <rect
            x="0"
            y="18"
            width="4"
            height="8"
            rx="1"
            fill="var(--train-gray)"
          ></rect>
          <rect
            x="6"
            y="12"
            width="52"
            height="26"
            rx="4"
            fill="#66bb6a"
          ></rect>
          <rect
            x="10"
            y="26"
            width="44"
            height="8"
            rx="2"
            fill="#a5d6a7"
          ></rect>
          <circle
            cx="18"
            cy="20"
            r="3"
            fill="#a5d6a7"
            opacity="0.6"
          ></circle>
          <circle
            cx="32"
            cy="20"
            r="3"
            fill="#a5d6a7"
            opacity="0.6"
          ></circle>
          <circle
            cx="46"
            cy="20"
            r="3"
            fill="#a5d6a7"
            opacity="0.6"
          ></circle>
          <circle
            cx="18"
            cy="6"
            r="6"
            fill="var(--train-dark)"
          ></circle>
          <circle
            cx="18"
            cy="6"
            r="3"
            fill="var(--train-gray)"
          ></circle>
          <circle
            cx="46"
            cy="6"
            r="6"
            fill="var(--train-dark)"
          ></circle>
          <circle
            cx="46"
            cy="6"
            r="3"
            fill="var(--train-gray)"
          ></circle>
          <rect
            x="58"
            y="18"
            width="6"
            height="8"
            rx="1"
            fill="var(--train-gray)"
          ></rect>
        </svg>
      </div>

      <SimpleText
        class="train-community-eyebrow"
        data-prop="eyebrow"
        text={eyebrow}
      />
      <Heading
        level="h2"
        size="xl"
        data-prop="heading"
      >
        {heading}
      </Heading>
      <Text
        class="train-community-subtext"
        data-prop="subtext"
        text={subtext}
      />

      <div
        class="train-community-stats"
        data-children-prop="stats"
      >
        {
          stats.map((stat: StatItem) => (
            <div
              class="train-stat-card"
              data-editable="array-item"
            >
              <span class="train-stat-value">{stat.value}</span>
              <span class="train-stat-label">{stat.label}</span>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</CustomSection>

<style>
  @layer page-sections {
    .train-community-inner {
      display: grid;
      grid-template-columns: 200px 1fr;
      gap: var(--spacing-2xl);
      align-items: center;
    }

    .train-community-track-space {
      min-height: 300px;
    }

    .train-community-content {
      max-width: 700px;
    }

    :global(.train-community-eyebrow) {
      font-size: 0.85rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--blue-600);
    }

    :global(.train-community-subtext) :global(p) {
      font-size: 1rem;
      line-height: 1.7;
      color: var(--color-text-muted);
      margin-top: var(--spacing-sm);
    }

    .train-community-stats {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: var(--spacing-md);
      margin-top: var(--spacing-xl);
    }

    .train-stat-card {
      display: flex;
      flex-direction: column;
      align-items: center;
      padding: var(--spacing-lg);
      background: var(--color-bg-surface);
      border: 1px solid var(--color-border);
      border-radius: 12px;
      text-align: center;
    }

    .train-stat-value {
      font-size: 2rem;
      font-weight: 800;
      color: var(--blue-600);
      line-height: 1;
    }

    .train-stat-label {
      font-size: 0.85rem;
      color: var(--color-text-muted);
      margin-top: 0.35rem;
    }

    @media (width < 768px) {
      .train-community-inner {
        grid-template-columns: 1fr;
      }
      .train-community-track-space {
        display: none;
      }
      .train-community-stats {
        grid-template-columns: repeat(2, 1fr);
      }
    }

    .train-mobile-float {
      display: none;
    }

    @media (width < 768px) {
      .train-mobile-float {
        display: flex;
        align-items: center;
        justify-content: flex-start;
        padding-left: 6%;
        margin-bottom: var(--spacing-lg);
        filter: drop-shadow(0 4px 8px rgba(0, 0, 0, 0.12));
        animation: train-piece-float 6.5s ease-in-out infinite;
        animation-delay: 1.5s;
      }

      .train-mobile-float svg {
        display: inline-block;
        flex-shrink: 0;
      }
    }

    @keyframes train-piece-float {
      0%,
      100% {
        transform: translateY(0) rotate(0deg);
      }
      33% {
        transform: translateY(-11px) rotate(-1.5deg);
      }
      66% {
        transform: translateY(-5px) rotate(2deg);
      }
    }
  }
</style>
