---
import CustomSection from "@builders/custom-section/CustomSection.astro";
import Heading from "@core-elements/heading/Heading.astro";
import Text from "@core-elements/text/Text.astro";
import SimpleText from "@core-elements/simple-text/SimpleText.astro";
import ButtonGroup from "@wrappers/button-group/ButtonGroup.astro";

const {
  eyebrow = "",
  heading = "",
  headingGradient = "",
  subtext = "",
  buttonSections = [],
  colorScheme = "inherit",
  backgroundColor,
  paddingVertical = "6xl",
  class: className,
  useDefaultEditableBinding = false,
  _component,
  ...htmlAttributes
} = Astro.props;
---

<CustomSection
  class:list={["train-hero", className]}
  maxContentWidth="2xl"
  paddingHorizontal="lg"
  paddingVertical={paddingVertical}
  colorScheme={colorScheme}
  backgroundColor={backgroundColor}
  useDefaultEditableBinding={useDefaultEditableBinding}
  {...htmlAttributes}
>
  <div class="train-hero-inner" id="hero">
    <div class="train-hero-badge">
      <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
        <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/>
      </svg>
      <SimpleText text={eyebrow} data-prop="eyebrow" />
    </div>

    <div class="train-hero-heading-wrap">
      <Heading level="h1" size="3xl" alignX="center" data-prop="heading">
        {heading}
      </Heading>
      {headingGradient && (
        <p class="train-hero-gradient" data-prop="headingGradient">{headingGradient}</p>
      )}
    </div>

    <Text alignX="center" class="train-hero-subtext" data-prop="subtext" text={subtext} />

    <ButtonGroup
      class="train-hero-buttons"
      buttonSections={buttonSections}
      alignX="center"
      data-children-prop="buttonSections"
    />

    <div class="train-hero-scroll-hint">
      <span>Scroll to begin the journey</span>
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="train-hero-arrow" aria-hidden="true">
        <path d="M12 5v14M5 12l7 7 7-7"/>
      </svg>
    </div>

    <!-- Floating code decorations -->
    <div class="train-hero-decorations" aria-hidden="true">
      <div class="train-hero-float train-hero-float-1">
        <svg width="60" height="60" viewBox="0 0 60 60"><rect x="5" y="5" width="50" height="50" rx="12" fill="var(--color-bg-accent)" stroke="var(--blue-300)" stroke-width="2"/><text x="30" y="38" text-anchor="middle" fill="var(--blue-600)" font-size="24" font-family="monospace">&lt;/&gt;</text></svg>
      </div>
      <div class="train-hero-float train-hero-float-2">
        <svg width="50" height="50" viewBox="0 0 50 50"><rect x="3" y="3" width="44" height="44" rx="10" fill="var(--yellow-100)" stroke="var(--yellow-300)" stroke-width="2"/><text x="25" y="32" text-anchor="middle" fill="var(--yellow-600)" font-size="20" font-family="monospace">{"{}"}</text></svg>
      </div>
      <div class="train-hero-float train-hero-float-3">
        <svg width="45" height="45" viewBox="0 0 45 45"><circle cx="22.5" cy="22.5" r="20" fill="var(--blue-50)" stroke="var(--blue-400)" stroke-width="2"/><text x="22.5" y="28" text-anchor="middle" fill="var(--blue-600)" font-size="16" font-family="monospace">fn</text></svg>
      </div>
      <div class="train-hero-float train-hero-float-4">
        <svg width="40" height="40" viewBox="0 0 40 40"><rect x="4" y="4" width="32" height="32" rx="8" fill="var(--yellow-50)" stroke="var(--yellow-400)" stroke-width="2"/><text x="20" y="26" text-anchor="middle" fill="var(--yellow-700)" font-size="14" font-family="monospace">**</text></svg>
      </div>
    </div>
  </div>
</CustomSection>

<style>
  @layer page-sections {
    .train-hero {
      :global(.outer-content) {
        background: linear-gradient(180deg, #fff 0%, var(--blue-50) 50%, #fff 100%);
      }
    }

    .train-hero-inner {
      min-height: 80vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      text-align: center;
      position: relative;
    }

    .train-hero-badge {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      padding: 0.35rem 0.85rem;
      border-radius: 999px;
      background: var(--blue-100);
      color: var(--blue-700);
      font-size: 0.8rem;
      font-weight: 600;
      margin-bottom: 1.5rem;
    }

    .train-hero-badge :global(div) {
      margin-top: 0 !important;
    }

    .train-hero-heading-wrap {
      margin-bottom: 1.5rem;
    }

    .train-hero-heading-wrap :global(h1) {
      font-size: clamp(2.5rem, 6vw, 4.5rem);
      font-weight: 800;
      line-height: 1.1;
      letter-spacing: -0.03em;
      margin-bottom: 0;
    }

    .train-hero-gradient {
      font-size: clamp(2.5rem, 6vw, 4.5rem);
      font-weight: 800;
      line-height: 1.1;
      letter-spacing: -0.03em;
      margin: 0;
      background: linear-gradient(135deg, var(--blue-500), var(--yellow-500));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    :global(.train-hero-subtext) :global(p) {
      font-size: 1.15rem;
      line-height: 1.7;
      color: var(--color-text-muted);
      max-width: 600px;
      margin-inline: auto;
    }

    :global(.train-hero-buttons) {
      margin-top: var(--spacing-xl) !important;
    }

    .train-hero-scroll-hint {
      margin-top: var(--spacing-2xl);
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.5rem;
      color: var(--color-text-muted);
      font-size: 0.85rem;
      opacity: 0.7;
    }

    .train-hero-arrow {
      animation: train-bounce-down 2s ease infinite;
    }

    @keyframes train-bounce-down {
      0%, 100% { transform: translateY(0); }
      50% { transform: translateY(6px); }
    }

    .train-hero-decorations {
      position: absolute;
      inset: 0;
      overflow: hidden;
      pointer-events: none;
      z-index: 0;
    }

    .train-hero-float {
      position: absolute;
      opacity: 0.5;
      animation: train-float 6s ease-in-out infinite;
    }

    .train-hero-float-1 { top: 10%; left: 5%; animation-delay: 0s; }
    .train-hero-float-2 { top: 15%; right: 8%; animation-delay: 1.5s; }
    .train-hero-float-3 { bottom: 20%; left: 10%; animation-delay: 3s; }
    .train-hero-float-4 { bottom: 15%; right: 12%; animation-delay: 4.5s; }

    @keyframes train-float {
      0%, 100% { transform: translateY(0) rotate(0deg); }
      50% { transform: translateY(-15px) rotate(3deg); }
    }

    @media (width < 640px) {
      .train-hero-float { display: none; }
    }
  }
</style>
